{
  "name": "ytdownloader",
  "version": "3.5.0",
  "description": "A GUI application to download videos and audio from YouTube and other platforms",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build",
    "build:linux": "electron-builder build --linux",
    "build:win": "electron-builder build --win",
    "build:mac": "electron-builder build --mac",
    "lint": "eslint src/"
  },
  "build": {
    "appId": "com.ytdownloader.app",
    "productName": "ytDownloader",
    "copyright": "Copyright © 2024",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network",
      "icon": "assets/icons"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": ["**/*"]
      }
    ]
  },
  "keywords": [
    "youtube",
    "downloader",
    "electron",
    "yt-dlp",
    "video",
    "audio"
  ],
  "author": "aandrew-me",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "i18next": "^23.7.16"
  }
}
